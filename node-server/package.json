{
  "name": "server",
  "version": "1.0.0",
  "main": "server.mjs",
  "bin": "dist/server.cjs",
  "type": "module",
  "scripts": {
  "bundle": "esbuild server.mjs --bundle --platform=node --format=cjs --external:serialport --external:@serialport/bindings-cpp --external:bufferutil --external:utf-8-validate --outfile=dist/server.cjs",
  "pkg": "pkg . --targets node20-win-x64 --no-bytecode --public --output dist/sidecar-server.exe",
  "build": "npm run bundle && npm run pkg"
},
  "dependencies": {
    "express": "^5.2.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.18.2",
    "esbuild": "^0.28.0"
  },
  "pkg": {
    "assets": ["node_modules/@serialport/bindings-cpp/prebuilds/**/*"],
    "scripts": []
  }
}