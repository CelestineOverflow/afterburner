{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "afterburner",
  "version": "0.2.3",
  "identifier": "com.afterburner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && node-server\\build-sidecar.bat",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "decorations": false,
        "title": "afterburner",
        "width": 500,
        "height": 800,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/sidecar-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERENzVCQTlENjk0RDc5QTQKUldTa2VVMXBuYnAxM1lFRkdGeThmam41dEtVMTYyaERHai9ZRFBRR082Y0I3eFFuaEhTUDN2TmsK",
      "endpoints": [
        "https://github.com/CelestineOverflow/afterburner/releases/latest/download/latest.json"
      ]
    }
  }
}